# Required — set a strong password for the site editor login
EDITOR_PASSWORD=Nasr2025

# Required — used to sign session cookies (use a long random string)
SESSION_SECRET=your-long-random-secret-string

# Optional — local dev port (Vercel sets PORT automatically)
PORT=3000

# Required on Vercel for persistent content and uploads
# Create a Blob store in Vercel: Project → Storage → Blob → Connect
BLOB_READ_WRITE_TOKEN=

# Contact form email (required for form submissions to work)
CONTACT_TO_EMAIL=magda@inceif.edu.my
CONTACT_FROM_EMAIL=noreply@nasreldinibrahimahmedhussien.com

# SMTP credentials — use your email provider (Gmail app password, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password-or-app-password
